# Backend API proxy (server/index.js)
PORT=8787
HOST=127.0.0.1

# OpenAI — servidor (backend/communities)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# OpenAI — cliente (importação de horários via IA, sem precisar do servidor)
# Use a mesma chave de OPENAI_API_KEY
VITE_OPENAI_API_KEY=your_openai_api_key

# Spotify (use client credentials OR a static access token)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# SPOTIFY_ACCESS_TOKEN=optional_static_access_token

# ExchangeRate-API
EXCHANGERATE_API_KEY=your_exchangerate_api_key

# Firebase (create project at https://console.firebase.google.com)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
